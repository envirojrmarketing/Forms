<script>
  function toggleProject(el) { el.classList.toggle('selected'); updateCount(); }
  function setTiming(btn, e) { e.stopPropagation(); btn.parentElement.querySelectorAll('.timing-btn').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }
  function updateCount() { const n = document.querySelectorAll('.project-item.selected').length; document.getElementById('selectedCount').textContent = n + (n === 1 ? ' project selected' : ' projects selected'); }
  function submitForm() {
    if (document.querySelectorAll('.project-item.selected').length === 0) { alert('Please tick at least one project!'); return; }
    document.getElementById('formBody').style.display = 'none';
    document.getElementById('successState').style.display = 'block';
  }
</script>
